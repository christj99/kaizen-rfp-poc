# Copy to .env and fill in values. Never commit .env.

# --- LLM providers ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
# OpenAI is used for embeddings only (Anthropic does not currently offer an embeddings API).
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# --- External sources ---
# Register a free key at https://sam.gov/content/api-keys
SAM_GOV_API_KEY=
# Slack Incoming Webhook URL (Slack App -> Incoming Webhooks)
SLACK_WEBHOOK_URL=

# Email (IMAP) ingestion — primary demo source. See README section
# "Demo email setup" for Gmail app-password walkthrough.
DEMO_EMAIL_USERNAME=meridian.rfps.demo@gmail.com
DEMO_EMAIL_PASSWORD=

# --- Postgres ---
# Use 127.0.0.1 (IPv4) rather than `localhost` to avoid conflicts with
# Windows IPv6 localhost bindings (e.g. WSL's wslrelay) that can intercept
# the connection and drop the handshake.
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=kaizen_rfp
POSTGRES_USER=kaizen
POSTGRES_PASSWORD=kaizen_dev_password
# Used by POST /admin/sql (the SQL Console page). Connects as a separate
# Postgres role with SELECT-only permission so the database rejects any
# write even if the application-level parser is bypassed.
POSTGRES_READONLY_PASSWORD=kaizen_readonly_pw

# --- n8n ---
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change-me
N8N_HOST=localhost
N8N_PORT=5678
# Generate from n8n UI: Settings -> n8n API -> Create an API key.
# Only needed for scripts/import_n8n_workflows.py. Never commit a real value.
N8N_API_KEY=

# --- API / UI ---
API_HOST=0.0.0.0
API_PORT=8000
STREAMLIT_PORT=8501

# --- Misc ---
# Set to 1 to run the LLM client in mock mode (no real Anthropic calls). Useful for tests.
LLM_MOCK_MODE=0
