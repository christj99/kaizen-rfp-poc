{
  "name": "Mode test — full_auto (ingest → screen → async draft)",
  "active": false,
  "settings": {
    "executionOrder": "v1",
    "saveManualExecutions": true
  },
  "nodes": [
    {
      "id": "1-webhook",
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [240, 300],
      "webhookId": "kaizen-full-auto-mode",
      "parameters": {
        "httpMethod": "POST",
        "path": "kaizen/full-auto-mode",
        "responseMode": "lastNode"
      },
      "notes": "Invoke with:\n  POST http://localhost:5678/webhook/kaizen/full-auto-mode\n  { \"rfp_id\": \"<uuid>\" }\n\nForces full_auto. /orchestrate kicks off drafting via BackgroundTasks (mode=async) — this workflow returns immediately with the draft_job_id. The 'Draft completion watcher' workflow fires the 'draft ready' Slack notification once the job completes."
    },
    {
      "id": "2-orchestrate",
      "name": "POST /orchestrate (full_auto)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [480, 300],
      "parameters": {
        "method": "POST",
        "url": "={{ $env.KAIZEN_API_URL }}/orchestrate",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={ \"rfp_id\": \"{{ $json.body.rfp_id }}\", \"mode_override\": \"full_auto\" }",
        "options": { "timeout": 600000 }
      }
    }
  ],
  "connections": {
    "Webhook": { "main": [[{ "node": "POST /orchestrate (full_auto)", "type": "main", "index": 0 }]] }
  }
}
